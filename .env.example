# Backend Environment Variables
# Copy this file to backend/.env and fill in your values

# Vector Store — use one
VECTOR_STORE_PROVIDER=pinecone
PINECONE_API_KEY=
PINECONE_INDEX_NAME=resumelens-resumes

# Or use Qdrant instead
QDRANT_URL=
QDRANT_API_KEY=

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Cloudflare R2 (optional — only for resume PDF storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=resumelens-resumes
R2_ENDPOINT=

# App
SECRET_KEY=your-secret-key-here
ENVIRONMENT=development
FRONTEND_URL=

# LLM Providers (optional — BYOK fallback only)
# Users provide their own keys via the Settings panel.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# Frontend Environment Variables
# Copy this file to frontend/.env.local

NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
